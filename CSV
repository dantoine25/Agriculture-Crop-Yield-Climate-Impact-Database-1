farm_ids = [f["FarmID"] for f in farms]
variety_names = [v["VarietyName"] for v in variety_infos]
used_gv_combos = set()
genetic_varieties = []
for i in range(1, 101):
    gvid = f"GV{i:03d}"
    while True:
        vname = random.choice(variety_names)
        fmid  = random.choice(farm_ids)
        if (vname, fmid) not in used_gv_combos:
            used_gv_combos.add((vname, fmid))
            break
    genetic_varieties.append(dict(VarietyID=gvid, VarietyName=vname, FarmID=fmid))

write_csv("geneticvariety.csv",
          ["VarietyID","VarietyName","FarmID"],
          genetic_varieties)


CROP_NAMES = ["Corn","Wheat","Soybean","Barley","Cotton","Rice","Oat",
              "Sunflower","Sorghum","Alfalfa","Canola","Peanut","Tomato",
              "Potato","Lettuce","Pepper","Cucumber","Cabbage"]

variety_yield = {v["VarietyName"]: v["TypicalYieldKgPerHa"] for v in variety_infos}

used_crop_keys = set()
crops = []
for i in range(1, 101):
    cid = f"C{i:03d}"
    while True:
        fmid = random.choice(farm_ids)
        crop_name = random.choice(CROP_NAMES)
        plant_date = rand_date(date(2023,1,1), date(2024,6,1))
        key = (fmid, plant_date, crop_name)
        if key not in used_crop_keys:
            used_crop_keys.add(key)
            break
    grow_days = random.randint(90, 270)
    harvest_date = plant_date + timedelta(days=grow_days)
    matching = [v for v in variety_names if crop_name.lower() in v.lower()]
    gv = random.choice(matching) if matching else random.choice(variety_names)
    notes_options = ["Irrigated weekly","Rain-fed","Minimal fertilizer",
                     "Cover crop rotation","Integrated pest management",
                     "No-till practice","Drip irrigation","Furrow irrigation"]
    crops.append(dict(CropID=cid, FarmID=fmid, CropName=crop_name,
                      PlantingDate=plant_date, HarvestDate=harvest_date,
                      GeneticVariety=gv, ManagementNotes=random.choice(notes_options)))

write_csv("crop.csv",
          ["CropID","FarmID","CropName","PlantingDate","HarvestDate",
           "GeneticVariety","ManagementNotes"],
          crops)


crop_ids  = [c["CropID"]  for c in crops]
crop_farm = {c["CropID"]: c["FarmID"] for c in crops}

yr_notes = ["Slight drought mid-season","Average rainfall year","Good yield no pests",
            "Early frost reduced yield","Excellent growing season",
            "Pest pressure managed","Fungal disease minor impact",
            "Flooding delayed planting","Record heat in July","Normal season"]

yield_records = []
for i in range(1, 101):
    yrid = f"YR{i:03d}"
    cid  = random.choice(crop_ids)
    fmid = crop_farm[cid]
    base_yield = float(variety_yield.get(
        next((c["GeneticVariety"] for c in crops if c["CropID"]==cid), None) or "Corn-X99",
        5000))
    actual_yield = round(base_yield * random.uniform(0.80, 1.05), 2)
    yield_records.append(dict(YieldRecordID=yrid, FarmID=fmid, CropID=cid,
                              Yield=actual_yield,
                              ManagementPracticeNotes=random.choice(yr_notes)))

write_csv("yieldrecord.csv",
          ["YieldRecordID","FarmID","CropID","Yield","ManagementPracticeNotes"],
          yield_records)


used_coords = set()
stations = []
for i in range(1, 101):
    wsid = f"WS{i:03d}"
    while True:
        lat = round(random.uniform(30.0, 49.0), 6)
        lon = round(random.uniform(-105.0, -80.0), 6)
        if (lat, lon) not in used_coords:
            used_coords.add((lat, lon))
            break
    elev = round(random.uniform(100, 600), 2)
    stations.append(dict(StationID=wsid, Latitude=lat, Longitude=lon, Elevation=elev))

write_csv("weatherstation.csv",
          ["StationID","Latitude","Longitude","Elevation"],
          stations)


station_ids = [s["StationID"] for s in stations]
used_obs_keys = set()
observations = []
for i in range(1, 101):
    oid = f"OBS{i:03d}"
    while True:
        sid = random.choice(station_ids)
        obs_dt = datetime(random.randint(2023,2024),
                          random.randint(1,12),
                          random.randint(1,28),
                          random.choice([6,8,10,12,14,16,18]),0)
        key = (sid, obs_dt)
        if key not in used_obs_keys:
            used_obs_keys.add(key)
            break
    temp   = round(random.uniform(-5, 40), 2)
    precip = round(random.uniform(0, 30), 2)
    solar  = round(random.uniform(5, 30), 2)
    press  = round(random.uniform(1005, 1025), 2)
    note   = random.choice(["Clear morning","Hot and dry","Overcast","Partly cloudy",
                             "Heavy rain","Light breeze","Foggy","Thunderstorm risk"])
    observations.append(dict(ObservationID=oid, StationID=sid,
                             ObserveDate=obs_dt.strftime("%Y-%m-%d %H:%M"),
                             TemperatureC=temp, PrecipitationMm=precip,
                             SolarRadiation=solar, IndPreseMMBs=press, Notes=note))

write_csv("climateobservation.csv",
          ["ObservationID","StationID","ObserveDate","TemperatureC",
           "PrecipitationMm","SolarRadiation","IndPreseMMBs","Notes"],
          observations)


