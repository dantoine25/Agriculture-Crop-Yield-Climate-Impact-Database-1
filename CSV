    farmers.append(dict(FarmerID=fid, FarmerName=fname, PhoneNumber=phone,
                        Email=email, Address=address, NationalID=nid))

write_csv("farmer.csv",
          ["FarmerID","FarmerName","PhoneNumber","Email","Address","NationalID"],
          farmers)


FARM_ADJECTIVES = ["Green","Sunset","Blue Ridge","Golden","Silver","Iron",
                   "Lone Star","Prairie","Harvest","Meadow","River","Hilltop",
                   "Valley","Morning","Twilight"]
FARM_NOUNS = ["Acres","Fields","Farm","Ranch","Homestead","Grove","Plains",
              "Pastures","Estates","Hollow"]

farmer_ids = [f["FarmerID"] for f in farmers]
farms = []
for i in range(1, 101):
    fmid = f"FM{i:02d}"
    name = random.choice(FARM_ADJECTIVES) + " " + random.choice(FARM_NOUNS)
    state = random.choice(STATES)
    location = f"{state}, USA"
    total = round(random.uniform(50, 500), 2)
    cultivated = round(total * random.uniform(0.6, 0.95), 2)
    organic = random.choice(["TRUE","FALSE"])
    farmer = random.choice(farmer_ids)
    farms.append(dict(FarmID=fmid, FarmName=name, Location=location,
                      TotalAreaHa=total, CultivatedAreaHa=cultivated,
                      OrganicCertified=organic, FarmerID=farmer))

write_csv("farm.csv",
          ["FarmID","FarmName","Location","TotalAreaHa","CultivatedAreaHa",
           "OrganicCertified","FarmerID"],
          farms)


