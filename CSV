        Texture          = random.choice(TEXTURES),
        LastSampleDate   = rand_date(date(2023,1,1), date(2024,6,1))
    ))

write_csv("soilprofile.csv",
          ["SoilProfileID","StationID","FarmID","pH","OrganicMatterPct",
           "Texture","LastSampleDate"],
          soil_profiles)

