import csv
import os
import random
import string
from datetime import date, timedelta, datetime

random.seed(42)
OUTPUT_DIR = "data"
os.makedirs(OUTPUT_DIR, exist_ok=True)


def rand_date(start: date, end: date) -> date:
    return start + timedelta(days=random.randint(0, (end - start).days))

def write_csv(filename: str, fieldnames: list, rows: list):
    path = os.path.join(OUTPUT_DIR, filename)
    with open(path, "w", newline="", encoding="utf-8") as f:
        writer = csv.DictWriter(f, fieldnames=fieldnames)
        writer.writeheader()
        writer.writerows(rows)
    print(f"  Wrote {len(rows):>4} rows → {path}")


FIRST_NAMES = ["Alice","Bob","Carol","David","Eve","Frank","Grace","Henry",
               "Iris","Jack","Karen","Leo","Mia","Nate","Olivia","Paul",
               "Quinn","Rachel","Sam","Tina","Uma","Victor","Wendy","Xander",
               "Yara","Zoe","Aaron","Beth","Carlos","Diana"]
LAST_NAMES  = ["Johnson","Martinez","Smith","Brown","Wilson","Moore","Taylor",
               "Anderson","Thomas","Jackson","White","Harris","Martin","Garcia",
               "Thompson","Robinson","Clark","Lewis","Lee","Walker","Hall",
               "Allen","Young","Hernandez","King","Wright","Lopez","Hill",
               "Scott","Green"]
STATES = ["Iowa","Kansas","Nebraska","Illinois","Indiana","Ohio","Minnesota",
          "Missouri","Wisconsin","Michigan","North Dakota","South Dakota",
          "Oklahoma","Texas","Colorado"]

farmers = []
used_nids = set()
for i in range(1, 101):
    fid = f"F{i:03d}"
    fname = random.choice(FIRST_NAMES) + " " + random.choice(LAST_NAMES)
    phone = f"555-{random.randint(1000,9999)}"
    email = fname.lower().replace(" ", ".") + f"{i}@farm.com"
    state = random.choice(STATES)
    address = f"{random.randint(1,999)} {random.choice(['Oak','Elm','Prairie','Ridge','Maple'])} {random.choice(['Lane','Rd','St','Ave','Dr'])}, {state}"
